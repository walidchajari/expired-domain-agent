# =============================================================================
# EXPIRED DOMAIN AGENT - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your credentials.

# --- ExpiredDomains.net Login ---
EXPIRED_USERNAME=your_email@example.com
EXPIRED_PASSWORD=your_password

# --- AI Provider (gemini or openai) ---
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini

# --- Gmail SMTP ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
EMAIL_TO=your_email@example.com
EMAIL_CC=

# --- Application Settings ---
DAILY_RUN_HOUR=08
DAILY_RUN_MINUTE=00
MAX_DOMAINS_TO_ANALYZE=200
TOP_N_DOMAINS=20
AI_SCORING_ENABLED=true
AI_SCORING_BATCH_SIZE=5
AI_SCORING_TIMEOUT=30
EXCEL_OUTPUT_DIR=reports
DATABASE_PATH=data/domains.db
LOG_LEVEL=INFO
LOG_FILE=data/agent.log
